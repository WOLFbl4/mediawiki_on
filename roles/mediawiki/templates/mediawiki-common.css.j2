/* Ansible managed site layout for Vector 2022. */
html,
body {
    min-height: 100%;
}

body.skin-vector-2022 {
    min-height: 100vh;
    min-height: 100dvh;
}

body.skin-vector-2022 .mw-page-container,
body.skin-vector-2022 .mw-page-container-inner {
    min-height: 100vh;
    min-height: 100dvh;
    max-width: none;
}

body.skin-vector-2022 .mw-content-container,
body.skin-vector-2022 .mw-body,
body.skin-vector-2022 #bodyContent,
body.skin-vector-2022 .mw-body-content {
    min-height: calc(100vh - 8rem);
    min-height: calc(100dvh - 8rem);
}

body.skin-vector-2022 .mw-body {
    width: 100%;
    max-width: none;
}

body.skin-vector-2022 .mw-parser-output > .full-height,
body.skin-vector-2022 .mw-parser-output iframe.full-height,
body.skin-vector-2022 .mw-parser-output object.full-height,
body.skin-vector-2022 .mw-parser-output embed.full-height {
    min-height: calc(100vh - 14rem);
    min-height: calc(100dvh - 14rem);
}
